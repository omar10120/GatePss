generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id                 Int      @id @default(autoincrement())
  timestamp          DateTime @default(now())
  userId             Int?     @map("user_id")
  actionType         String   @map("action_type")
  actionPerformed    String   @map("action_performed")
  affectedEntityType String?  @map("affected_entity_type")
  affectedEntityId   Int?     @map("affected_entity_id")
  details            Json?

  user User? @relation(fields: [userId], references: [id])

  @@index([actionType])
  @@index([timestamp])
  @@index([userId])
  @@map("activity_logs")
}

model fqa {
  id          Int      @id @default(autoincrement())
  question_en String
  question_ar String
  answer_en   String   @db.Text
  answer_ar   String   @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime
}

model Notification {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  actionType         String   @map("action_type")
  actionPerformed    String   @map("action_performed")
  actionPerformedAr  String?  @map("action_performed_ar")
  affectedEntityType String?  @map("affected_entity_type")
  affectedEntityId   Int?     @map("affected_entity_id")
  isRead             Boolean  @default(false) @map("is_read")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model pass_types {
  id         Int      @id @default(autoincrement())
  name_en    String
  name_ar    String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime
}

model Permission {
  id              Int              @id @default(autoincrement())
  key             String           @unique
  description     String
  userPermissions UserPermission[]

  @@map("permissions")
}

model Request {
  id                           Int      @id @default(autoincrement())
  requestNumber                String   @unique @map("request_number")
  applicantNameEn              String   @map("applicant_name_en")
  applicantNameAr              String   @map("applicant_name_ar")
  applicantEmail               String   @map("applicant_email")
  applicantPhone               String?  @map("applicant_phone")
  gender                       String
  profession                   String
  otherProfessions             String?  @map("other_professions")
  bloodType                    String?  @map("blood_type")
  photoPath                    String?  @map("photo_path")
  passportIdNumber             String   @map("passport_id_number")
  passportIdImagePath          String?  @map("passport_id_image_path")
  nationality                  String
  identification               String
  organization                 String
  validFrom                    DateTime @map("valid_from")
  validTo                      DateTime @map("valid_to")
  purposeOfVisit               String   @map("purpose_of_visit") @db.Text
  dateOfVisit                  DateTime @map("date_of_visit")
  requestType                  String   @map("request_type")
  status                       String   @default("PENDING")
  rejectionReason              String?  @map("rejection_reason") @db.Text
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")
  approvedById                 Int?     @map("approved_by")
  externalReference            String?  @map("external_reference")
  lastIntegrationStatusCode    Int?     @map("last_integration_status_code")
  lastIntegrationStatusMessage String?  @map("last_integration_status_message") @db.Text
  qrCodePdfUrl                 String?  @map("qr_code_pdf_url")
  passFor                      String?  @map("pass_for")

  approvedBy User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  uploads    Upload[]

  @@index([approvedById])
  @@index([createdAt])
  @@index([dateOfVisit])
  @@index([requestType])
  @@index([status])
  @@index([validFrom])
  @@index([validTo])
  @@map("requests")
}

model Upload {
  id         Int      @id @default(autoincrement())
  requestId  Int      @map("request_id")
  fileType   String   @map("file_type")
  filePath   String   @map("file_path")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("uploads")
}

model UserPermission {
  id           Int @id @default(autoincrement())
  userId       Int @map("user_id")
  permissionId Int @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@map("user_permissions")
}

model User {
  id               Int              @id @default(autoincrement())
  name             String
  email            String           @unique
  phoneNumber      String?          @map("phone_number")
  passwordHash     String           @map("password_hash")
  role             String           @default("SUB_ADMIN")
  isActive         Boolean          @default(true) @map("is_active")
  otpCode          String?          @map("otp_code")
  otpExpiresAt     DateTime?        @map("otp_expires_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  activityLogs     ActivityLog[]
  notifications    Notification[]
  approvedRequests Request[]        @relation("ApprovedBy")
  userPermissions  UserPermission[]

  @@map("users")
}
