            "faqs": {
                "item1": {
                    "q": "How long does it take to get a permit?",
                    "a": "The processing time for a permit typically varies depending on the type of request. Generally, it takes between 24-48 hours for standard applications. You will receive an email notification once your permit is approved."
                },
                "item2": {
                    "q": "How do I get a permit when I need it?",
                    "a": "You can request a permit through our online portal by filling out the application form and uploading the required documents. Once submitted, our team will review your request."
                },
                "item3": {
                    "q": "What documents are required for the application?",
                    "a": "Required documents typically include a valid ID, company registration details, and specific documents related to your visit or vehicle entry."
                },
                "item4": {
                    "q": "How can I track my application status?",
                    "a": "You can track your application status using the 'Track Application' button on the home page and entering your reference number."
                },
                "item5": {
                    "q": "Is there a fast-track option available?",
                    "a": "Yes, we offer fast-track processing for urgent needs. Please select the 'Fast-Track' option during the application process."
                },
                "item6": {
                    "q": "What should I do if my permit is rejected?",
                    "a": "If your permit is rejected, you will receive an email with the reason for rejection. You can correct the issues and resubmit your application."
                }
            },
