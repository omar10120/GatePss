# Database Configuration (SQLite - No installation required!)
DATABASE_URL="file:./dev.db"

# JWT Secret (auto-generated for development)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-12345"

# Email (defaults in src/lib/smtp-config.ts match production if unset)
SMTP_HOST="gatepass.majis.om"
SMTP_PORT="465"
SMTP_USER="info@gatepass.majis.om"
SMTP_PASSWORD="your-mailbox-password"
EMAIL_FROM="info@gatepass.majis.om"
ADMIN_EMAIL_GROUP="your-email@gmail.com"

# Sohar Port Integration (Mock mode enabled by default)
SOHAR_PORT_API_URL="https://api.soharport.com/gate-pass"
SOHAR_PORT_API_KEY="your-api-key-here"
SOHAR_PORT_MOCK_MODE="true"
# Public app origin; attachment URLs are built as `{origin}/api/uploads/...` (override prefix with GATEPASS_PUBLIC_UPLOAD_PREFIX if needed)
# NEXT_PUBLIC_APP_URL="https://gatepass.majis.om"
# GATEPASS_FILES_BASE_URL="https://gatepass.majis.om"
# GATEPASS_PUBLIC_UPLOAD_PREFIX="api"

# Application Settings
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OTP (optional)
# AUTH_OTP_DISABLED="true"
# AUTH_OTP_BYPASS_EMAILS="amr.dawoodi@hotmail.com,amrooody7@gmail.com"
# AUTH_OTP_LOG_CODE="true"

# Production PM2: `npm start` preloads .env via dotenv (see package.json).
# SMTP cPanel: gatepass.majis.om:465 or 127.0.0.1:465, SMTP_SKIP_VERIFY=true

# Production cPanel (same server as mail) — if verify() fails but mail works:
# SMTP_HOST="mail.gatepass.majis.om"
# SMTP_PORT="465"
# SMTP_USER="info@gatepass.majis.om"
# SMTP_PASSWORD="mailbox-password"
# EMAIL_FROM="info@gatepass.majis.om"
# SMTP_SKIP_VERIFY="true"
# SMTP_TLS_REJECT_UNAUTHORIZED="false"
